rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    /** Firestore rules `isPlatformAdmin()` 과 동일 */
    function isPlatformAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email in [
          'drive5746@gmail.com',
          'ingompunch@gmail.com'
        ];
    }

    function isValidCompanyId(companyId) {
      return companyId.matches('^[a-z0-9_]{1,64}$');
    }

    function isValidReservationId(reservationId) {
      return reservationId.matches('^[a-zA-Z0-9_-]{1,128}$');
    }

    // 차량 사진: reservations/{companyId}/{reservationId}/images/…
    match /reservations/{companyId}/{reservationId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && isValidCompanyId(companyId)
        && isValidReservationId(reservationId)
        && request.resource.size < 15 * 1024 * 1024;
    }

    // 가맹점 주차장 사진: companies/{companyId}/parking/…
    // 쓰기는 본사만 (AdminDashboard). 읽기는 공개(B2C MY 등).
    match /companies/{companyId}/{allPaths=**} {
      allow read: if true;
      allow write: if isPlatformAdmin()
        && isValidCompanyId(companyId)
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
