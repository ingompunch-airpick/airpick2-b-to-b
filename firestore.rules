rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'drive5746@gmail.com' ||
        request.auth.token.email == 'ingompunch@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. Entity Validations
    function isValidCompany(data) {
      return data.keys().hasAll(['name', 'base_price', 'extra_day_price', 'is_indoor']) &&
             data.name is string && data.name.size() <= 100 &&
             data.is_indoor is bool;
    }

    function isValidReservation(data) {
      return data.keys().hasAll(['userId', 'companyId', 'totalPrice']) &&
             data.userId == request.auth.uid &&
             data.companyId is string &&
             data.companyId.size() <= 128 &&
             data.totalPrice >= 0;
    }

    function isValidParkingLot(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() <= 100;
    }

    // 4. Match Rules for Collections

    // companies
    match /companies/{companyId} {
      allow read: if true; // Publicly readable for comparison
      allow create, update, delete: if isAdmin() && isValidId(companyId) && isValidCompany(incoming());
    }

    // reservations
    match /reservations/{reservationId} {
      allow read: if isSignedIn() && (isAdmin() || (existing().userId == request.auth.uid));
      allow create: if isSignedIn() && isValidId(reservationId) && isValidReservation(incoming());
      allow update: if isSignedIn() && (
        isAdmin() || (
          existing().userId == request.auth.uid &&
          isValidReservation(incoming()) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
          incoming().status == 'cancelled'
        )
      );
      allow delete: if isAdmin();
    }

    // parking_lots
    match /parking_lots/{parkingLotId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() && isValidId(parkingLotId) && isValidParkingLot(incoming());
    }
  }
}
