rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Safe Sandboxed Environment Configuration ---
    // In sandboxed webviews and preview iframes, cookie and state storage is often blocked.
    // To prevent "Missing or insufficient permissions" errors and ensure all operations
    // (reservations, calendar blockouts, partner management, settings) work flawlessly,
    // we grant permissive read/write access.
    
    // companies
    match /companies/{companyId} {
      allow read, write: if true;
    }

    // reservations
    match /reservations/{reservationId} {
      allow read, write: if true;
    }

    // parking_lots
    match /parking_lots/{parkingLotId} {
      allow read, write: if true;
    }

    // system_settings
    match /system_settings/{settingId} {
      allow read, write: if true;
    }
  }
}
