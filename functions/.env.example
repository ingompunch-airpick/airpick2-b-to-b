# 카카오 알림톡 — Cloud Functions 환경 변수
# 복사: cp .env.example .env 후 값 입력 → firebase deploy --only functions

# true 로 설정해야 발송 (기본 false — 템플릿 승인·키 준비 전 안전)
ALIMTALK_ENABLED=false

# 발송 업체: nhn (기본) | ncp
ALIMTALK_PROVIDER=nhn

# --- NHN Cloud (ALIMTALK_PROVIDER=nhn) ---
# NHN Cloud > Notification > KakaoTalk Bizmessage > AppKey
NHN_ALIMTALK_APP_KEY=
# NHN Cloud > AppKey 옆 Secret Key
NHN_ALIMTALK_SECRET_KEY=
# 발신 프로필 @airpickup 의 Sender Key (40자)
NHN_ALIMTALK_SENDER_KEY=

# --- 네이버 클라우드 SENS (ALIMTALK_PROVIDER=ncp) ---
# 1차: reservation(예약완료)만 검증 → CHECKIN/CHECKOUT은 비워 두면 스킵
# 포털 > 마이페이지 > 인증키 관리 (Access Key / Secret Key)
NCP_ALIMTALK_ACCESS_KEY=
NCP_ALIMTALK_SECRET_KEY=
# SENS > Biz Message > 프로젝트 서비스 ID (프로젝트 상세에서 확인)
NCP_ALIMTALK_SERVICE_ID=
# 카카오 채널 ID (예: @airpick)
NCP_ALIMTALK_PLUS_FRIEND_ID=@airpickup
# 콘솔에 등록 완료된 템플릿 코드
NCP_ALIMTALK_TEMPLATE_RESERVE=reservation
NCP_ALIMTALK_TEMPLATE_CHECKIN=
NCP_ALIMTALK_TEMPLATE_CHECKOUT=

# --- Google Sheets 예약 장부 ---
SHEETS_ARCHIVE_ENABLED=false
GOOGLE_SHEETS_SPREADSHEET_ID=1zxxMHH7cJDz_nyCQbPOt2GCHdBtAVY9mzBDnUVV6lTs
# 서비스 계정 JSON 전체를 한 줄로 (minify) 붙여넣기
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=
