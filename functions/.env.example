# NHN Cloud 카카오 알림톡 — Cloud Functions 환경 변수
# 복사: cp .env.example .env 후 값 입력 → firebase deploy --only functions

# true 로 설정해야 발송 (기본 false — 템플릿 승인·키 준비 전 안전)
ALIMTALK_ENABLED=false

# NHN Cloud > Notification > KakaoTalk Bizmessage > AppKey
NHN_ALIMTALK_APP_KEY=

# NHN Cloud > AppKey 옆 Secret Key
NHN_ALIMTALK_SECRET_KEY=

# 발신 프로필 @airpickup 의 Sender Key (40자, 콘솔 > 발신프로필에서 확인)
NHN_ALIMTALK_SENDER_KEY=

# --- Google Sheets 예약 장부 ---
SHEETS_ARCHIVE_ENABLED=false
GOOGLE_SHEETS_SPREADSHEET_ID=1zxxMHH7cJDz_nyCQbPOt2GCHdBtAVY9mzBDnUVV6lTs
# 서비스 계정 JSON 전체를 한 줄로 (minify) 붙여넣기
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=
