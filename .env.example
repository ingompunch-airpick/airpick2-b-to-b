# Firebase 플랫폼 관리자 (Firestore rules isPlatformAdmin — companies 생성/삭제, system_settings)
# Firebase Console → Authentication → 해당 이메일 계정 등록 후 비밀번호 설정
VITE_FIREBASE_ADMIN_EMAIL=ingompunch@gmail.com
VITE_FIREBASE_ADMIN_PASSWORD=

# 네이버 지도 (주차장 핀) — OAuth NAVER_CLIENT_ID 와 별개
# https://console.ncloud.com/naver-service/application → Maps → Client ID
# Web 서비스 URL에 http://localhost:3000 및 배포 도메인 등록
VITE_NAVER_MAP_CLIENT_ID=

# Social Login (추후)
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=
# KAKAO_CLIENT_ID=
# KAKAO_CLIENT_SECRET=
